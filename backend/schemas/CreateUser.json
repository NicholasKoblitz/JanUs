{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "$id": "http://example.com/example.json",
    "type": "object",
    "default": {},
    "title": "Root Schema",
    "required": [
        "firstName",
        "lastName",
        "username",
        "password",
        "isTeacher"
    ],
    "properties": {
        "firstName": {
            "type": "string",
            "default": "",
            "title": "The firstName Schema",
            "examples": [
                "John"
            ]
        },
        "lastName": {
            "type": "string",
            "default": "",
            "title": "The lastName Schema",
            "examples": [
                "Doe"
            ]
        },
        "username": {
            "type": "string",
            "default": "",
            "title": "The username Schema",
            "examples": [
                "johnman"
            ]
        },
        "password": {
            "type": "string",
            "default": "",
            "title": "The password Schema",
            "examples": [
                "Password1"
            ]
        },
        "isTeacher": {
            "type": "boolean",
            "default": false,
            "title": "The isTeacher Schema",
            "examples": [
                true
            ]
        }
    },
    "examples": [{
        "firstName": "John",
        "lastName": "Doe",
        "username": "johnman",
        "password": "Password1",
        "isTeacher": true
    }]
}